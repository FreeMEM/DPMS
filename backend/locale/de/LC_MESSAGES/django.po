msgstr "Alles, was du über %(title)s wissen musst"

msgid "Getting there"
msgstr "Anreise"

msgid "Practical info"
msgstr "Praktische Infos"

msgid "Contact"
msgstr "Kontakt"

msgid "Thanks to our sponsors for making this event possible."
msgstr "Danke an unsere Sponsoren, die dieses Event möglich machen."

msgid "Event in progress!"
msgstr "Event läuft!"
